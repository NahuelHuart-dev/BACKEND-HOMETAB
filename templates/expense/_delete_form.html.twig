<form method="post" action="{{ path('app_expense_delete', {'id': expense.id}) }}" onsubmit="return confirm('Vols eliminar aquesta despesa?');" class="ht-inline-form">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ expense.id) }}">
    <button type="submit" class="ht-btn ht-btn--danger-outline"><span class="pi pi-trash"></span> Eliminar</button>
</form>
