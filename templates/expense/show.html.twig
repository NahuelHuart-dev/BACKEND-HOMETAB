{% extends 'base.html.twig' %}

{% block title %}Despesa · HomeTab{% endblock %}

{% block body %}
<div class="ht-page-head">
    <div>
        <div class="ht-mini-tag">Gastos</div>
        <h1 class="ht-display">{{ expense.title }}</h1>
        <p class="ht-lead ht-muted">{{ expense.amount|number_format(2, ',', '.') }} € · {{ expense.category }}</p>
    </div>
    <div class="ht-actions">
        <a href="{{ path('app_expense_index') }}" class="ht-btn ht-btn--secondary"><span class="pi pi-arrow-left"></span> Llistat</a>
        <a href="{{ path('app_expense_edit', {'id': expense.id}) }}" class="ht-btn ht-btn--primary"><span class="pi pi-pencil"></span> Editar</a>
    </div>
</div>

<div class="ht-grid" style="grid-template-columns: 1fr; gap: var(--space-4); max-width: 720px;">
    <div class="ht-card">
        <table class="ht-table">
            <tbody>
                <tr><th scope="row">Descripció</th><td>{{ expense.description|default('—') }}</td></tr>
                <tr><th scope="row">Data pagament</th><td>{{ expense.paidAt ? expense.paidAt|date('d/m/Y H:i') : '—' }}</td></tr>
                <tr><th scope="row">Pagada</th><td>{% if expense.isPaid %}<span class="ht-badge ht-badge--ok">Sí</span>{% else %}<span class="ht-badge ht-badge--bad">No</span>{% endif %}</td></tr>
                <tr><th scope="row">Notes</th><td>{{ expense.notes|default('—') }}</td></tr>
            </tbody>
        </table>
    </div>
    <div class="ht-card">
        <p class="ht-lead ht-muted" style="margin:0 0 var(--space-3);">Eliminar aquest registre</p>
        {{ include('expense/_delete_form.html.twig') }}
    </div>
</div>
{% endblock %}
