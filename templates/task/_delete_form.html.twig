<form method="post" action="{{ path('app_task_delete', {'id': task.id}) }}" onsubmit="return confirm('Vols eliminar aquesta tasca?');" class="ht-inline-form">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ task.id) }}">
    <button type="submit" class="ht-btn ht-btn--danger-outline"><span class="pi pi-trash"></span> Eliminar</button>
</form>
