{% extends 'base.html.twig' %}

{% block title %}Editar tasca · HomeTab{% endblock %}

{% block body %}
<div class="ht-page-head">
    <div>
        <div class="ht-mini-tag">Tasques</div>
        <h1 class="ht-display">Editar tasca</h1>
    </div>
    <div class="ht-actions">
        <a href="{{ path('app_task_index') }}" class="ht-btn ht-btn--secondary"><span class="pi pi-arrow-left"></span> Llistat</a>
        <a href="{{ path('app_task_show', {'id': task.id}) }}" class="ht-btn ht-btn--ghost"><span class="pi pi-eye"></span> Veure</a>
    </div>
</div>

<div class="ht-card" style="max-width:720px;">
    {{ include('task/_form.html.twig', {'button_label': 'Actualitzar'}) }}
</div>

<div class="ht-card" style="max-width:720px;margin-top:var(--space-4);">
    <p class="ht-lead ht-muted" style="margin:0 0 var(--space-3);">Zona perillosa</p>
    {{ include('task/_delete_form.html.twig') }}
</div>
{% endblock %}
