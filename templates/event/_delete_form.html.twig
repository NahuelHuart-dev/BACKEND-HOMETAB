<form method="post" action="{{ path('app_event_delete', {'id': event.id}) }}" onsubmit="return confirm('Vols eliminar aquest esdeveniment?');" class="ht-inline-form">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ event.id) }}">
    <button type="submit" class="ht-btn ht-btn--danger-outline"><span class="pi pi-trash"></span> Eliminar</button>
</form>
